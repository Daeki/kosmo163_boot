<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.winter.app.board.notice.NoticeMapper">
  	<!-- File  -->
  	<insert id="createFile" parameterType="NoticeFileDTO">
  		INSERT INTO TB_NOTICEFILE
  		VALUES(BOARD_SEQ.NEXTVAL, #{fileName}, #{oriName}, #{boardNum}) 
  	</insert>
  
  
  
  	<!-- File 끝 -->
  	<sql id="search">
  		WHERE 
		<choose>
			<when test="kind=='v2'">BOARD_CONTENTS</when>
			<when test="kind=='v3'">BOARD_WRITER</when>
			<otherwise>BOARD_TITLE</otherwise>
		</choose>
  		
  		LIKE '%'||#{search}||'%'
  	</sql>
  	
  	<select id="detail" parameterType="NoticeDTO" resultType="NoticeDTO">
  		SELECT * FROM TB_NOTICE WHERE BOARD_NUM=#{boardNum}
  	</select>
  	
  
  	<select id="getCount" resultType="Long" parameterType="Pager">
  		SELECT COUNT(BOARD_NUM) FROM TB_NOTICE
  		<include refid="search"></include>
  	</select>
  
  	<!-- list -->
  	<select id="list" resultType="NoticeDTO" parameterType="Pager">
  		
			SELECT * FROM
				(
					SELECT ROWNUM R, T.* FROM
					(
						SELECT * FROM TB_NOTICE
						<include refid="search"></include>
						ORDER BY BOARD_NUM DESC
					) T
				)
			WHERE R BETWEEN #{first} AND #{last}
		
  	</select>

    <!-- create -->	
    <insert id="create" parameterType="NoticeDTO">
    	<selectKey order="BEFORE" resultType="Long" keyProperty="boardNum">
  			SELECT BOARD_SEQ.NEXTVAL FROM DUAL
  		</selectKey>
    	INSERT INTO TB_NOTICE 
    	VALUES (#{boardNum}, #{boardTitle}, #{boardContents}, #{boardWriter}, sysdate, 0)
    </insert>
    
  </mapper>