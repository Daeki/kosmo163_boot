<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.winter.app.board.qna.QnaMapper">
    <!-- File 끝 -->
  	<sql id="search">
  		WHERE 
		<choose>
			<when test="kind=='v2'">BOARD_CONTENTS</when>
			<when test="kind=='v3'">BOARD_WRITER</when>
			<otherwise>BOARD_TITLE</otherwise>
		</choose>
  		
  		LIKE '%'||#{search}||'%'
  	</sql>
  	
  	 <select id="getCount" resultType="Long" parameterType="Pager">
  		SELECT COUNT(BOARD_NUM) FROM TB_NOTICE
  		<include refid="search"></include>
  	</select>
    	<!-- list -->
  	<select id="list" resultType="QnaDTO" parameterType="Pager">
  		
			SELECT * FROM
				(
					SELECT ROWNUM R, T.* FROM
					(
						SELECT * FROM TB_QNA
						<include refid="search"></include>
						ORDER BY BOARD_REF DESC, BOARD_STEP ASC
					) T
				)
			WHERE R BETWEEN #{first} AND #{last}
		
  	</select>

    <!-- create -->	
    <insert id="create" parameterType="QnaDTO">
    	<selectKey order="BEFORE" resultType="Long" keyProperty="boardNum">
    		SELECT BOARD_SEQ.NEXTVAL FROM DUAL
    	</selectKey>
    	
    	INSERT INTO TB_QNA 
    	VALUES 
    	(	
    		#{boardNum}, 
    		#{boardTitle}, 
    		#{boardContents}, 
    		#{boardWriter}, 
    		sysdate, 
    		0,
    		<if test="boardRef != null">
    			#{boardRef},
    		</if>
    		<if test="boardRef == null">
    			#{boardNum},
    		</if>
    		#{boardStep},
    		#{boardDepth}	
    	)
    </insert>
    
    <update id="replyUpdate" parameterType="QnaDTO">
    	UPDATE TB_QNA SET BOARD_STEP=BOARD_STEP+1
    	WHERE BOARD_REF=#{boardRef} AND BOARD_STEP>#{boardStep}
    </update>
    
      	<select id="detail" parameterType="QnaDTO" resultMap="detailResult">
  		SELECT *
		FROM TB_QNA N
			 LEFT JOIN 
			 TB_QNAFILE NF
			 USING(BOARD_NUM)
		WHERE BOARD_NUM = #{boardNum}
  	</select>
  	
  	<resultMap type="QnaDTO" id="detailResult">
  		<!-- ID => Primary key -->
  		<id column="BOARD_NUM" property="boardNum"/>
  		<!-- 그외 나머지 -->
  		<result column="BOARD_TITLE" property="boardTitle"/>
  		<result column="BOARD_WRITER" property="boardWriter"/>
  		<result column="BOARD_CONTENTS" property="boardContents"/>
  		<result column="BOARD_DATE" property="boardDate"/>
  		<result column="BOARD_HIT" property="boardHit"/>
  		<result column="BOARD_REF" property="boardRef"/>
  		<result column="BOARD_STEP" property="boardStep"/>
  		<result column="BOARD_DEPTH" property="boardDepth"/>
  
  		
  		<!-- 1:N -->
  		<collection property="list" javaType="java.util.List" ofType="NoticeFileDTO">
  			<id column="FILE_NUM" property="fileNum"/>
  			<result column="FILE_NAME" property="fileName"/>
  			<result column="ORI_NAME" property="oriName"/>
  
  		</collection>
  		
  	
  	</resultMap>
    
    
   
    
    
  </mapper>